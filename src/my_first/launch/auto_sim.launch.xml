<?xml version="1.0"?>
<launch>
  <let name="urdf_file" value="$(find-pkg-share my_first)/urdf/my_robot.urdf" />

  <node pkg="robot_state_publisher" exec="robot_state_publisher" output="screen">
    <param name="robot_description" value="$(file-content $(var urdf_file))" type="str" />
  </node>

  <node pkg="motion_simulation" exec="trajectory_publisher" output="screen" />

  <node pkg="rviz2" exec="rviz2" output="screen" args="-d $(find-pkg-share my_first)/config/config.rviz" />
</launch>