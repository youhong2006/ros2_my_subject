<?xml version="1.0"?>
<launch>
  <let name="world_file" value="$(find-pkg-share test_robot_gazebo)/worlds/empty.world" />

  <include file="$(find-pkg-share ros_gz_sim)/launch/gz_sim.launch.py">
    <arg name="gz_args" value="-s -r $(var world_file)"/>
  </include>

  <include file="$(find-pkg-share ros_gz_sim)/launch/gz_sim.launch.py">
    <arg name="gz_args" value="-g --render-engine ogre"/>
    <arg name="on_exit_shutdown" value="True"/>
  </include>

<node pkg="ros_gz_bridge" exec="parameter_bridge" output="screen"
        args="/clock@rosgraph_msgs/msg/Clock[gz.msgs.Clock" />
</launch>